variable "environment_short" {
  default = "{{.environment_short}}"
}

variable "environment" {
  default = "{{.environment}}"
}

variable "product" {
  default = "{{.product}}"
}

variable "resource_group_location" {
  default     = "westus2"
  description = "Location of the resource group."
}

variable "resource_group_name" {
  default = {{.resource_group_name}}
}

variable "vault_vm_size" {
  default = {{.vault_vm_size}}
}

variable "vm_image_urn" {
  type        = string
  default     = "{{.vm_image_urn}}"
  description = "VM image URN. Use microsoftcblmariner:azure-linux-3:azure-linux-3-gen2-fips:latest for Azure Linux FIPS."
}

variable "vm_admin_username" {
  type        = string
  default     = "{{.vm_admin_username}}"
  description = "Admin username used for the VM and Terraform provisioner SSH connections."
}

variable "org_name" {
  type    = string
  default = {{.org_name}}
}

# Using heredoc '<<' in terraform doesn't
# allow for terraforms variable substitution.
# This will bypass that limitation in the
# install script.
variable "write_service" {
  type    = string
  default = "<<"
}

variable "mysql_backup_retention_days" {
  type    = number
  default = 30
}